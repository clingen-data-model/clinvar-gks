{
   "$schema": "https://json-schema.org/draft/2020-12/schema",
   "$id": "https://w3id.org/ga4gh/schema/clinvar-gks/1.x/clinvar-gks/json/ClinvarNotProvidedProposition",
   "title": "ClinvarNotProvidedProposition",
   "description": "A proposition for ClinVar submissions where the submitter did not provide a clinical classification. These submissions still carry variant-condition associations but lack a formal pathogenicity or clinical significance assessment.",
   "type": "object",
   "maturity": "draft",
   "allOf": [
      {
         "$refCurie": "va-spec:ClinicalVariantProposition"
      }
   ],
   "properties": {
      "type": {
         "type": "string",
         "const": "ClinvarNotProvidedProposition",
         "default": "ClinvarNotProvidedProposition",
         "description": "MUST be \"ClinvarNotProvidedProposition\"."
      },
      "predicate": {
         "type": "string",
         "const": "hasNoProvidedClassificationFor",
         "default": "hasNoProvidedClassificationFor",
         "description": "The relationship the Proposition describes between the subject variant and object condition. MUST be \"hasNoProvidedClassificationFor\"."
      },
      "objectCondition": {
         "oneOf": [
            {
               "$ref": "/ga4gh/schema/gks-core/1.1.0/json/iriReference"
            },
            {
               "$ref": "/ga4gh/schema/va-spec/1.0.1/base/json/Condition"
            }
         ],
         "description": "The condition for which no classification was provided."
      }
   },
   "required": [
      "objectCondition",
      "predicate"
   ],
   "additionalProperties": false
}
