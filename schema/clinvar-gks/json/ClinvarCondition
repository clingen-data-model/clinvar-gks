{
   "$schema": "https://json-schema.org/draft/2020-12/schema",
   "$id": "https://w3id.org/ga4gh/schema/clinvar-gks/1.x/clinvar-gks/json/ClinvarCondition",
   "title": "ClinvarCondition",
   "description": "A ClinVar condition (disease, phenotype, or trait) represented as a MappableConcept with ClinVar-specific extensions. The primaryCoding uses MedGen as the canonical coding system with cross-mappings to OMIM, MONDO, Orphanet, HPO, MeSH, and SNOMED CT.",
   "$defs": {
      "ExtensionClinvarTraitType": {
         "type": "object",
         "maturity": "draft",
         "description": "The type of trait as classified by ClinVar (e.g., \"Disease\", \"Finding\", \"DrugResponse\").",
         "protectedClassOf": "ClinvarCondition",
         "properties": {
            "name": {
               "type": "string",
               "const": "clinvarTraitType",
               "description": "Must be 'clinvarTraitType'."
            },
            "value": {
               "type": "string",
               "enum": [
                  "Disease",
                  "DrugResponse",
                  "Finding",
                  "NamedProteinVariant",
                  "PhenotypeInstruction"
               ],
               "description": "The ClinVar trait type."
            }
         },
         "required": [],
         "additionalProperties": false
      },
      "ExtensionClinvarTraitSetType": {
         "type": "object",
         "maturity": "draft",
         "description": "The ClinVar trait set type (e.g., \"Disease\", \"DrugResponse\", \"Finding\").",
         "protectedClassOf": "ClinvarCondition",
         "properties": {
            "name": {
               "type": "string",
               "const": "clinvarTraitSetType",
               "description": "Must be 'clinvarTraitSetType'."
            },
            "value": {
               "type": "string",
               "description": "The ClinVar trait set type."
            }
         },
         "required": [],
         "additionalProperties": false
      },
      "ExtensionAliases": {
         "type": "object",
         "maturity": "draft",
         "description": "Alternative names or synonyms for the condition as reported in ClinVar.",
         "protectedClassOf": "ClinvarCondition",
         "properties": {
            "name": {
               "type": "string",
               "const": "aliases",
               "description": "Must be 'aliases'."
            },
            "value": {
               "type": "string",
               "description": "Comma-separated alternative names for the condition."
            }
         },
         "required": [],
         "additionalProperties": false
      },
      "ExtensionClinvarTraitId": {
         "type": "object",
         "maturity": "draft",
         "description": "The ClinVar internal trait identifier (e.g., \"6752\").",
         "protectedClassOf": "ClinvarCondition",
         "properties": {
            "name": {
               "type": "string",
               "const": "clinvarTraitId",
               "description": "Must be 'clinvarTraitId'."
            },
            "value": {
               "type": "string",
               "description": "The ClinVar trait identifier."
            }
         },
         "required": [],
         "additionalProperties": false
      },
      "ExtensionSubmittedScvTraitAssignment": {
         "type": "object",
         "maturity": "draft",
         "description": "Describes how the SCV submission's trait was assigned to a ClinVar trait (e.g., \"scv trait: preferred name 'cystic fibrosis'\", \"scv trait: medgen id 'c0406612'\").",
         "protectedClassOf": "ClinvarCondition",
         "properties": {
            "name": {
               "type": "string",
               "const": "submittedScvTraitAssignment",
               "description": "Must be 'submittedScvTraitAssignment'."
            },
            "value": {
               "type": "string",
               "description": "The trait assignment description."
            }
         },
         "required": [],
         "additionalProperties": false
      },
      "ExtensionClinvarScvTraitAssignment": {
         "type": "object",
         "maturity": "draft",
         "description": "Describes the ClinVar-side trait mapping method used for this SCV (e.g., \"rcv-tm medgen id\", \"rcv-tm preferred name\").",
         "protectedClassOf": "ClinvarCondition",
         "properties": {
            "name": {
               "type": "string",
               "const": "clinvarScvTraitAssignment",
               "description": "Must be 'clinvarScvTraitAssignment'."
            },
            "value": {
               "type": "string",
               "description": "The ClinVar trait mapping method."
            }
         },
         "required": [],
         "additionalProperties": false
      },
      "ExtensionClinvarScvTraitMappingType": {
         "type": "object",
         "maturity": "draft",
         "description": "The detailed trait mapping type and reference value used by ClinVar to map the SCV's submitted trait to a ClinVar trait (e.g., \"xref:medgen(c0406612)\", \"name:preferred(cystic fibrosis)\").",
         "protectedClassOf": "ClinvarCondition",
         "properties": {
            "name": {
               "type": "string",
               "const": "clinvarScvTraitMappingType:ref(val)",
               "description": "Must be 'clinvarScvTraitMappingType:ref(val)'."
            },
            "value": {
               "type": "string",
               "description": "The mapping type with reference field and value."
            }
         },
         "required": [],
         "additionalProperties": false
      },
      "ClinvarConditionProperties": {
         "type": "object",
         "maturity": "draft",
         "description": "ClinVar-specific extensions for conditions (diseases, phenotypes, traits). These extensions capture ClinVar trait metadata and submission-level trait assignment information.",
         "protectedClassOf": "ClinvarCondition",
         "properties": {
            "extensions": {
               "type": "array",
               "ordered": false,
               "items": {
                  "oneOf": [
                     {
                        "$ref": "#/$defs/ExtensionClinvarTraitId"
                     },
                     {
                        "$ref": "#/$defs/ExtensionClinvarTraitType"
                     },
                     {
                        "$ref": "#/$defs/ExtensionAliases"
                     },
                     {
                        "$ref": "#/$defs/ExtensionSubmittedScvXrefs"
                     },
                     {
                        "$ref": "#/$defs/ExtensionSubmittedScvTraitAssignment"
                     },
                     {
                        "$ref": "#/$defs/ExtensionClinvarScvTraitAssignment"
                     },
                     {
                        "$ref": "#/$defs/ExtensionClinvarScvTraitMappingType"
                     },
                     {
                        "$ref": "#/$defs/ExtensionClinvarTraitSetType"
                     },
                     {
                        "$ref": "#/$defs/ExtensionClinvarTraitSetId"
                     }
                  ]
               },
               "description": "ClinVar condition extensions including trait identifiers, type, aliases, cross-references, and submission-level trait assignment metadata."
            }
         },
         "additionalProperties": false,
         "required": []
      },
      "ExtensionClinvarTraitSetId": {
         "type": "object",
         "maturity": "draft",
         "description": "The ClinVar internal trait set identifier (e.g., \"25780\").",
         "protectedClassOf": "ClinvarCondition",
         "properties": {
            "name": {
               "type": "string",
               "const": "clinvarTraitSetId",
               "description": "Must be 'clinvarTraitSetId'."
            },
            "value": {
               "type": "string",
               "description": "The ClinVar trait set identifier."
            }
         },
         "required": [],
         "additionalProperties": false
      },
      "ExtensionSubmittedScvXrefs": {
         "type": "object",
         "maturity": "draft",
         "description": "Cross-references submitted by the SCV submitter for this condition. Each entry contains a code and system identifying the condition in an external terminology.",
         "protectedClassOf": "ClinvarCondition",
         "properties": {
            "name": {
               "type": "string",
               "const": "submittedScvXrefs",
               "description": "Must be 'submittedScvXrefs'."
            },
            "value": {
               "type": "array",
               "ordered": false,
               "items": {
                  "$ref": "/ga4gh/schema/gks-core/1.1.0/json/Coding"
               },
               "description": "Array of Coding objects with code and system for each cross-reference."
            }
         },
         "required": [],
         "additionalProperties": false
      }
   },
   "maturity": "draft",
   "allOf": [
      {
         "$ref": "/ga4gh/schema/gks-core/1.1.0/json/MappableConcept"
      },
      {
         "$ref": "#/$defs/ClinvarConditionProperties"
      }
   ]
}
