{
   "$schema": "https://json-schema.org/draft/2020-12/schema",
   "$id": "https://w3id.org/ga4gh/schema/clinvar-gks/1.x/clinvar-gks/json/ClinvarAffectsProposition",
   "title": "ClinvarAffectsProposition",
   "description": "A proposition describing a variant that affects a condition without implying causality. Used for ClinVar submissions classified as \"affects\". ClinVar has stopped accepting new submissions with this classification, but historical submissions remain.",
   "type": "object",
   "maturity": "draft",
   "allOf": [
      {
         "$refCurie": "va-spec:ClinicalVariantProposition"
      }
   ],
   "properties": {
      "type": {
         "type": "string",
         "const": "ClinvarAffectsProposition",
         "default": "ClinvarAffectsProposition",
         "description": "MUST be \"ClinvarAffectsProposition\"."
      },
      "predicate": {
         "type": "string",
         "const": "hasAffectFor",
         "default": "hasAffectFor",
         "description": "The relationship the Proposition describes between the subject variant and object condition. MUST be \"hasAffectFor\"."
      },
      "objectCondition": {
         "oneOf": [
            {
               "$ref": "/ga4gh/schema/gks-core/1.1.0/json/iriReference"
            },
            {
               "$ref": "/ga4gh/schema/va-spec/1.0.1/base/json/Condition"
            }
         ],
         "description": "The condition that is affected by the variant."
      }
   },
   "required": [
      "objectCondition",
      "predicate"
   ],
   "additionalProperties": false
}
