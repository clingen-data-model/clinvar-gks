{
   "$schema": "https://json-schema.org/draft/2020-12/schema",
   "$id": "https://w3id.org/ga4gh/schema/clinvar-gks/1.x/clinvar-gks/json/ClinvarDrugResponseProposition",
   "title": "ClinvarDrugResponseProposition",
   "description": "A proposition describing the role of a variant in modulating drug response. Used for ClinVar submissions classified as \"drug response\". Distinct from the GA4GH VariantTherapeuticResponseProposition which is used for somatic clinical impact therapeutic response assertions.",
   "type": "object",
   "maturity": "draft",
   "allOf": [
      {
         "$refCurie": "va-spec:ClinicalVariantProposition"
      }
   ],
   "properties": {
      "type": {
         "type": "string",
         "const": "ClinvarDrugResponseProposition",
         "default": "ClinvarDrugResponseProposition",
         "description": "MUST be \"ClinvarDrugResponseProposition\"."
      },
      "predicate": {
         "type": "string",
         "const": "hasDrugResponseFor",
         "default": "hasDrugResponseFor",
         "description": "The relationship the Proposition describes between the subject variant and object condition. MUST be \"hasDrugResponseFor\"."
      },
      "objectCondition": {
         "oneOf": [
            {
               "$ref": "/ga4gh/schema/gks-core/1.1.0/json/iriReference"
            },
            {
               "$ref": "/ga4gh/schema/va-spec/1.0.1/base/json/Condition"
            }
         ],
         "description": "The condition context in which the drug response is observed."
      }
   },
   "required": [
      "objectCondition",
      "predicate"
   ],
   "additionalProperties": false
}
